generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

generator nestjsDto {
  provider        = "prisma-generator-nestjs-dto"
  output          = "../src/generated"
  createDtoPrefix = "Create"
  updateDtoPrefix = "Update"
  dtoSuffix       = "Dto"
  entityPrefix    = ""
  entitySuffix    = "Entity"
  classValidation = "true"
  fileNamingStyle = "kebab"
  outputType      = "class"
}

datasource db {
  provider = "postgresql"
}

enum MBTI {
  ISTJ
  ISFJ
  INFJ
  INTJ
  ISTP
  ISFP
  INFP
  INTP
  ESTP
  ESFP
  ENFP
  ENTP
  ESTJ
  ESFJ
  ENFJ
  ENTJ

  @@map("mbti")
}

enum LoveLanguage {
  words_of_affirmation
  acts_of_service
  receiving_gifts
  quality_time
  physical_touch

  @@map("love_language")
}

enum ZodiacSign {
  aries
  taurus
  gemini
  cancer
  leo
  virgo
  libra
  scorpio
  sagittarius
  capricorn
  aquarius
  pisces

  @@map("zodiac_sign")
}

enum RelationshipType {
  friend
  family
  colleague
  partner
  acquaintance
  romantic
  other

  @@map("relationship_type")
}

enum RoleType {
  USER
  ADMIN
  SUPERADMIN

  @@map("role_type")
}

enum LoginType {
  LOCAL
  GOOGLE

  @@map("login_type")
}

model User {
  id                         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  displayName                String?   @map("display_name")
  avatarUrl                  String?   @map("avatar_url")
  role                       RoleType  @default(USER) @map("role")
  email                      String    @unique @map("email")
  password                   String?   @map("password")
  isAllowUserData            Boolean   @default(true) @map("is_allow_user_data")
  isEmailVerified            Boolean   @default(false) @map("is_email_verified")
  verificationToken          String?   @map("verification_token")
  verificationTokenExpiresAt DateTime? @map("verification_token_expires_at") @db.Timestamptz(6)
  loginType                  LoginType @default(LOCAL) @map("login_type")

  mbti          MBTI?          @map("mbti")
  zodiacSign    ZodiacSign?    @map("zodiac_sign")
  loveLanguages LoveLanguage[] @default([]) @map("love_languages")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  tokens Token[]

  @@map("users")
}

model Token {
  id           String @id(map: "pk_token") @default(dbgenerated("uuid_generate_v4()")) @map("id") @db.Uuid
  deviceId     String @map("device_id")
  userId       String @map("user_id") @db.Uuid
  refreshToken String @map("refresh_token") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deviceId, userId], map: "ixuq_token_user_device")
  @@map("tokens")
}

model Mentor {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String  @unique
  avatarUrl String? @map("avatar_url")

  philosophy    String?
  mindset       String?
  style         String?
  speakingStyle String?
  bodyLanguage  String?

  bio       String?
  era       String?
  archetype String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  topics  MentorTopic[]
  sources BookVideoSource[]
  quotes  MentorQuote[]

  @@map("mentors")
}

model Topic {
  id   String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentorTopics MentorTopic[]
  ideas        SourceIdea[]

  @@map("topics")
}

model MentorTopic {
  mentorId String @db.Uuid
  topicId  String @db.Uuid

  mentor Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  topic  Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([mentorId, topicId])
  @@map("mentor_topics")
}

enum SourceType {
  book
  video
  podcast
  article

  @@map("source_type")
}

model BookVideoSource {
  id       String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mentorId String? @map("mentor_id") @db.Uuid

  sourceTitle String     @map("source_title")
  sourceType  SourceType @map("source_type")

  creator   String?
  sourceUrl String? @map("source_url")
  filePath  String? @map("file_path")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  mentor Mentor? @relation(fields: [mentorId], references: [id])

  ideas SourceIdea[]

  @@map("book_video_sources")
}

model SourceIdea {
  id       String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sourceId String  @map("source_id") @db.Uuid
  topicId  String? @map("topic_id") @db.Uuid

  ideaText   String  @map("idea_text")
  core       String?
  importance String?

  application String?
  example     String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  source BookVideoSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  topic  Topic?          @relation(fields: [topicId], references: [id])

  @@index([sourceId])
  @@map("source_ideas")
}

model MentorQuote {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  mentorId String @db.Uuid

  quote   String
  meaning String?

  createdAt DateTime @default(now())

  mentor Mentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("mentor_quotes")
}
